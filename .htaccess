<IfModule mod_mime.c>
  AddType application/manifest+json .webmanifest
</IfModule>
Options -Indexes
RewriteEngine On

# Impede a exposicao direta de fontes, dependencias e documentacao interna.
RewriteRule ^(?:src|docs|node_modules)/ - [F,L,NC]

<FilesMatch "(?i)\.(?:md|sql|ts|tsx|map|lock)$">
  Require all denied
</FilesMatch>

<FilesMatch "(?i)^(?:package(?:-lock)?\.json|tsconfig(?:\.[^.]+)?\.json|vite\.config\.ts)$">
  Require all denied
</FilesMatch>

# Serve o build Vite sem interferir no admin, API, uploads e configurações PHP.
RewriteRule ^$ dist/index.html [L]
RewriteRule ^(assets/.*|favicon-48\.png|apple-touch-icon\.png|icon-192\.png|icon-512\.png|site\.webmanifest|favicon\.svg|logo-gns\.png|og-image\.jpg|robots\.txt|sitemap\.xml)$ dist/$1 [L]

<IfModule mod_headers.c>
  Header always unset X-Powered-By
  Header always set X-Frame-Options "DENY"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
  Header always set Content-Security-Policy "default-src 'self'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self'; connect-src 'self'"
</IfModule>
